# Server
PORT=5000
NODE_ENV=development

# Database (Hostinger MySQL)
DB_HOST=srv1234.hstgr.io
DB_PORT=3306
DB_NAME=athnav_website
DB_USER=athnav_user
DB_PASSWORD=your_db_password

# Email (SMTP via Hostinger / Gmail)
SMTP_HOST=mail.athnav.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=info@athnav.com
SMTP_PASS=your_email_password
EMAIL_FROM="Athnav Integrated Solutions <info@athnav.com>"
EMAIL_TO=info@athnav.com

# JWT (for admin auth)
JWT_SECRET=your_strong_jwt_secret_here
JWT_EXPIRES_IN=7d

# CORS
ALLOWED_ORIGINS=https://athnav.com,https://www.athnav.com,http://localhost:5173

# Clerk (optional - for authenticated portal features)
CLERK_SECRET_KEY=sk_live_your_clerk_key
CLERK_PUBLISHABLE_KEY=pk_live_your_clerk_key
